# Environment variables for AgentLine

# LLM Config
GEMINI_API_KEY=your_gemini_api_key_here

# Sarvam AI Config (STT and TTS)
SARVAM_API_KEY=your_sarvam_api_key_here

# Database Config
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=agentline

# Email Tool Configuration (SMTP or Resend API)
# For SMTP:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com

# For Resend (Optional):
RESEND_API_KEY=

# Exotel Telephony config (For cloud inbound mode)
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SUBDOMAIN=
EXOTEL_VIRTUAL_NUMBER=
